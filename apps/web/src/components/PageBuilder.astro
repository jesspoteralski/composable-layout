---
import { toAttrs } from '../lib/attrs';
import DisplayItem from './DisplayItem.astro';

interface Props {
  sections: any[];
}

const { sections = [] } = Astro.props;
---

{sections.map((section:any) => {
  const attrs = toAttrs(section.styles);
  const items = (section.items ?? []).filter(Boolean);

  if (section._type === 'layoutStack') {
    return (
      <layout-stack {...attrs}>
        {items.map((item: any) => <DisplayItem item={item} />)}
      </layout-stack>
    );
  }

  if (section._type === 'layoutRow') {
    return (
      <layout-row columns={section.columns ?? '50/50'} {...attrs}>
        {items.map((item: any) => <DisplayItem item={item} />)}
      </layout-row>
    );
  }

  if (section._type === 'layoutGrid') {
    return (
      <layout-grid min-item-width={section.minItemWidth ?? '280px'} {...attrs}>
        {items.map((item: any) => <DisplayItem item={item} />)}
      </layout-grid>
    );
  }

  return null;
})}
