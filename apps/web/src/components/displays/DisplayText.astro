---
import { toHTML } from '@portabletext/to-html';
import { toAttrs } from '../../lib/attrs';

interface Props {
  item: any;
}

const { item } = Astro.props;
const attrs = toAttrs(item.styles);

function renderPortableText(content: any[]): string {
  if (!content) return '';
  try {
    return toHTML(content);
  } catch {
    return '';
  }
}
---

<display-text {...attrs}>
  <Fragment set:html={renderPortableText(item.content)} />
</display-text>
