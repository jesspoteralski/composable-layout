---
import { toAttrs } from '../../lib/attrs';

interface Props {
  item: any;
}

const { item } = Astro.props;
const attrs = toAttrs(item.styles);
---

<display-card
  image-src={item.imageSrc ?? ''}
  image-alt={item.imageAlt ?? ''}
  heading={item.heading ?? ''}
  body={item.body ?? ''}
  cta-text={item.ctaText ?? ''}
  cta-href={item.ctaHref ?? ''}
  {...attrs}
/>
