---
import DisplayText from './displays/DisplayText.astro';
import DisplayImage from './displays/DisplayImage.astro';
import DisplayCard from './displays/DisplayCard.astro';

interface Props {
  item: any;
}

const { item } = Astro.props;
---

{item._type === 'displayText' && <DisplayText item={item} />}
{item._type === 'displayImage' && <DisplayImage item={item} />}
{item._type === 'displayCard' && <DisplayCard item={item} />}
